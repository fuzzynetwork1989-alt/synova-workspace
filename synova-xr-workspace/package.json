{
  "name": "@synova/xr-workspace",
  "version": "4.1.0",
  "description": "Synova AI XR/VR/AR Workspace - Meta Quest 3 ready app",
  "main": "App.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile quest3",
    "build:preview": "eas build --platform android --profile preview",
    "build:production": "eas build --platform android --profile production",
    "submit": "eas submit --platform android",
    "dev": "expo start --dev-client"
  },
  "dependencies": {
    "@viro-community/react-viro": "^2.41.0",
    "expo": "~50.0.0",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "expo-av": "~13.10.0",
    "expo-sensors": "~12.7.0",
    "expo-camera": "~13.4.0",
    "expo-speech": "~11.3.0",
    "expo-network": "~5.8.0",
    "@react-native-async-storage/async-storage": "1.19.3",
    "react-native-fs": "^2.20.0",
    "three": "^0.159.0",
    "@react-three/fiber": "^8.15.0",
    "@react-three/drei": "^9.88.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "typescript": "^5.1.3",
    "eas-cli": "^7.0.0",
    "expo-cli": "^6.3.0"
  },
  "keywords": ["synova", "xr", "vr", "ar", "viroreact", "quest3", "metaverse"],
  "author": "Synova AI",
  "license": "MIT"
}
